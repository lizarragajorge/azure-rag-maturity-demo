# Azure AI Search
SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
SEARCH_INDEX_NAME=utility-ops

# Azure OpenAI / Foundry
AOAI_ENDPOINT=https://<your-foundry-resource>.openai.azure.com/
AOAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AOAI_EMBEDDING_MODEL=text-embedding-3-large
AOAI_EMBEDDING_DIMENSIONS=3072
AOAI_CHAT_DEPLOYMENT=gpt-5-mini
AOAI_CHAT_MODEL=gpt-5-mini

# Agentic retrieval (post-Build 2026)
KNOWLEDGE_SOURCE_NAME=utility-knowledge-source
KNOWLEDGE_BASE_NAME=utility-knowledge-base
